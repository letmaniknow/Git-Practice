# =============================================================================
/dist
/tmp
/out-tsc
/bazel-out
/build
*.js
*.js.map
*.css
*.css.map

# =============================================================================
# DEPENDENCIES & NODE MODULES
# =============================================================================
/node_modules
/node_modules - copia
/node_modules - backup
/node_modules - old
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# ANGULAR CACHE & BUILD
# =============================================================================
/.angular/cache
.ng
.angular

# =============================================================================
