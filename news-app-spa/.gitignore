*.log
logs/
*.temp
*.tmp
*.bak
*.backup
*.swp
*.swo
*~
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings
*.rar
*.zip
*.7z
*.tar.gz

# Build logs
build.log
npm-build.log
yarn-build.log

# =============================================================================
# ENVIRONMENT & CONFIGURATION FILES
# =============================================================================
# Environment files (NEVER commit sensitive data)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
environment.dev.ts
environment.prod.ts
.env.*
!.env.example

# =============================================================================
# PACKAGE MANAGER LOCK FILES (Consider committing these for reproducibility)
# =============================================================================
# Uncomment if you prefer NOT to commit lock files:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# =============================================================================
# ANGULAR / TYPESCRIPT
# =============================================================================
/typings
tslint.json
*.js
!*.config.js
!karma.conf.js
!protractor.conf.js
*.js.map
*.d.ts

# =============================================================================
# DIST & ARTIFACTS
# =============================================================================
/dist
/bazel-out
/bazel-bin

# =============================================================================
# MISCELLANEOUS
# =============================================================================
.prettierignore
.prettierrc
.eslintignore
*.orig
merge_file_*
.git/objects/pack/*.tmp
.git/logs/

# Docker files (if using Docker)
.dockerignore
docker-compose.override.yml

# Git
.git/hooks
.git/info/exclude
