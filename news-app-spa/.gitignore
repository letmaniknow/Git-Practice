.classpath
.project
.c9/
*.launch
.settings/
*.tern-port

# IntelliJ IDEA
*.swp
*.swo
*~
.classpath
.factorypath
.c9/
*.launch
.settings/
.vscode-test
*.user
*.userosscache
*.sln.docstates

# VS Code extensions folder
.vscode-test

# =============================================================================
